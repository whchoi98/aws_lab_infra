<%- include('partials/header') %>

<section class="orders-page">
  <h1 class="page-title"><%= t.orders %></h1>

  <% if (orders && orders.length > 0) { %>
    <div class="orders-table-wrapper">
      <table class="orders-table">
        <thead>
          <tr>
            <th><%= t.order_id || 'Order ID' %></th>
            <th><%= t.date || 'Date' %></th>
            <th><%= t.status || 'Status' %></th>
            <th><%= t.total || 'Total' %></th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order) { %>
            <%
              var orderTotal = 0;
              if (order.items && Array.isArray(order.items)) {
                order.items.forEach(function(item) { orderTotal += (item.totalCost || item.unitCost || 0); });
              }
              var orderDate = order.date || order.createdAt || new Date().toISOString();
              var orderStatus = order.status || 'completed';
            %>
            <tr>
              <td class="order-id"><%= order.id ? order.id.substring(0, 8) + '...' : 'N/A' %></td>
              <td><%= new Date(orderDate).toLocaleDateString(lang === 'ko' ? 'ko-KR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
              <td>
                <span class="status-badge status-<%= orderStatus.toLowerCase() %>">
                  <%= lang === 'ko' ? (orderStatus === 'completed' ? '완료' : orderStatus === 'pending' ? '처리중' : orderStatus) : orderStatus %>
                </span>
              </td>
              <td>
                <%= lang === 'ko' ? '₩' + orderTotal.toLocaleString() : '$' + orderTotal.toFixed(2) %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p><%= t.no_orders %></p>
      <a href="/catalog" class="btn btn-primary"><%= t.continue_shopping %></a>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
