<%- include('partials/header') %>

<section class="hero">
  <div class="hero-badge"><%= lang === 'ko' ? '🚀 AWS EKS 기반 마이크로서비스' : '🚀 Powered by AWS EKS Microservices' %></div>
  <h1><%= t.welcome %></h1>
  <p class="hero-desc"><%= t.welcome_desc %></p>
  <div class="hero-actions">
    <a href="/catalog" class="btn btn-primary btn-lg"><%= t.all_products %> →</a>
    <a href="/orders" class="btn btn-secondary btn-lg"><%= t.orders %></a>
  </div>
  <div class="hero-stats">
    <div class="stat"><span class="stat-num">6</span><span class="stat-label"><%= lang === 'ko' ? '상품' : 'Products' %></span></div>
    <div class="stat"><span class="stat-num">5</span><span class="stat-label"><%= lang === 'ko' ? '마이크로서비스' : 'Microservices' %></span></div>
    <div class="stat"><span class="stat-num">∞</span><span class="stat-label"><%= lang === 'ko' ? '확장성' : 'Scalability' %></span></div>
  </div>
</section>

<section class="featured">
  <div class="section-header">
    <h2 class="section-title"><%= t.featured %></h2>
    <a href="/catalog" class="section-link"><%= t.all_products %> →</a>
  </div>
  <div class="product-grid">
    <% if (products && products.length > 0) { %>
      <% products.forEach(function(product, i) { %>
        <a href="/product/<%= product.id %>" class="product-card">
          <% if (i === 0) { %><div class="card-badge"><%= lang === 'ko' ? '🔥 인기' : '🔥 Hot' %></div><% } %>
          <% if (product.price > 3000) { %><div class="card-badge premium"><%= lang === 'ko' ? '👑 프리미엄' : '👑 Premium' %></div><% } %>
          <div class="product-image">
            <div class="image-placeholder">
              <span><%= ['⌚','🕰️','⏱️','🪵','📱','💪'][i % 6] %></span>
            </div>
          </div>
          <div class="product-info">
            <h3 class="product-name"><%= product.name %></h3>
            <% if (product.tag && product.tag.length > 0) { %>
              <div class="product-tags">
                <% product.tag.forEach(function(tag) { %>
                  <span class="tag"><%= tag %></span>
                <% }); %>
              </div>
            <% } %>
            <div class="product-meta">
              <p class="product-price">
                <%= lang === 'ko' ? '₩' + Number(product.price).toLocaleString() : '$' + Number(product.price).toFixed(2) %>
              </p>
              <% if (product.count) { %>
                <span class="product-stock"><%= lang === 'ko' ? product.count + '개 남음' : product.count + ' left' %></span>
              <% } %>
            </div>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <% var names = lang === 'ko' ? ['클래식 시계','포켓 워치','크로노그래프','우드 워치'] : ['Classic Watch','Pocket Watch','Chronograph','Wood Watch']; %>
      <% var emojis = ['⌚','🕰️','⏱️','🪵']; %>
      <% for (var i = 0; i < 4; i++) { %>
        <div class="product-card placeholder-card">
          <div class="product-image">
            <div class="image-placeholder"><span><%= emojis[i] %></span></div>
          </div>
          <div class="product-info">
            <h3 class="product-name"><%= names[i] %></h3>
            <p class="product-price"><%= lang === 'ko' ? '₩10,000' : '$9.99' %></p>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>
</section>

<section class="features-section">
  <h2 class="section-title"><%= lang === 'ko' ? '왜 LAB Shop인가?' : 'Why LAB Shop?' %></h2>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">🏗️</div>
      <h3><%= lang === 'ko' ? '마이크로서비스 아키텍처' : 'Microservices Architecture' %></h3>
      <p><%= lang === 'ko' ? 'UI, Catalog, Cart, Checkout, Orders - 5개 독립 서비스로 구성' : '5 independent services: UI, Catalog, Cart, Checkout, Orders' %></p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">☁️</div>
      <h3><%= lang === 'ko' ? 'AWS EKS 기반' : 'Runs on AWS EKS' %></h3>
      <p><%= lang === 'ko' ? 'Kubernetes 오케스트레이션, Graviton 인스턴스, Auto Scaling' : 'Kubernetes orchestration, Graviton instances, Auto Scaling' %></p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🌍</div>
      <h3><%= lang === 'ko' ? '한국어 / English' : 'Korean / English' %></h3>
      <p><%= lang === 'ko' ? '실시간 언어 전환, 쿠키 기반 언어 기억' : 'Real-time language switching with cookie persistence' %></p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📊</div>
      <h3><%= lang === 'ko' ? '구조화된 로깅' : 'Structured Logging' %></h3>
      <p><%= lang === 'ko' ? 'JSON 로그, X-Request-ID 추적, 응답 시간 측정' : 'JSON logs, X-Request-ID tracing, response time metrics' %></p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
