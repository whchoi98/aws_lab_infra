<%- include('partials/header') %>

<section class="hero">
  <h1><%= t.welcome %></h1>
  <p class="hero-desc"><%= t.welcome_desc %></p>
</section>

<section class="featured">
  <h2 class="section-title"><%= t.featured %></h2>
  <div class="product-grid">
    <% if (products && products.length > 0) { %>
      <% products.forEach(function(product) { %>
        <a href="/product/<%= product.id %>" class="product-card">
          <div class="product-image">
            <div class="image-placeholder">
              <span>📦</span>
            </div>
          </div>
          <div class="product-info">
            <h3 class="product-name"><%= product.name %></h3>
            <p class="product-price">
              <%= lang === 'ko' ? '₩' + Number(product.price).toLocaleString() : '$' + Number(product.price).toFixed(2) %>
            </p>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <% for (var i = 0; i < 4; i++) { %>
        <div class="product-card placeholder-card">
          <div class="product-image">
            <div class="image-placeholder">
              <span>📦</span>
            </div>
          </div>
          <div class="product-info">
            <h3 class="product-name"><%= t.sample_product %> <%= i + 1 %></h3>
            <p class="product-price">
              <%= lang === 'ko' ? '₩10,000' : '$9.99' %>
            </p>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
