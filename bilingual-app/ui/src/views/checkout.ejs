<%- include('partials/header') %>

<section class="checkout-page">
  <h1 class="page-title"><%= t.checkout || 'Checkout' %></h1>

  <form action="/checkout/place-order" method="POST" class="checkout-form">
    <div class="form-row">
      <div class="form-group">
        <label for="first_name"><%= t.first_name || 'First Name' %></label>
        <input type="text" id="first_name" name="first_name" required>
      </div>
      <div class="form-group">
        <label for="last_name"><%= t.last_name || 'Last Name' %></label>
        <input type="text" id="last_name" name="last_name" required>
      </div>
    </div>

    <div class="form-group">
      <label for="email"><%= t.email || 'Email' %></label>
      <input type="email" id="email" name="email" required>
    </div>

    <div class="form-group">
      <label for="address"><%= t.address || 'Address' %></label>
      <input type="text" id="address" name="address" required>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="city"><%= t.city || 'City' %></label>
        <input type="text" id="city" name="city" required>
      </div>
      <div class="form-group">
        <label for="zip"><%= t.zip || 'Zip Code' %></label>
        <input type="text" id="zip" name="zip" required>
      </div>
    </div>

    <div class="checkout-actions">
      <a href="/cart" class="btn btn-secondary">&larr; <%= t.back_to_cart || 'Back to Cart' %></a>
      <button type="submit" class="btn btn-primary btn-lg"><%= t.place_order %></button>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
